# Secrets and credentials for the Electron main process.
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# PostHog telemetry (project API key)
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# Google Calendar OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Outlook Calendar OAuth2 (PKCE public client — no client secret)
OUTLOOK_CLIENT_ID=
